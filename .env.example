LLM_GPU_BENCHMARKING_MINIMUM_TPS_THRESHOLD=100
LLM_GPU_BENCHMARKING_VALIDATION_MODE=local
LLM_GPU_BENCHMARKING_LOCAL_LLM_ROOT=.runtime/local-llm
LLM_GPU_BENCHMARKING_LOCAL_LLM_PROFILES_PATH=src/config/local_llm_profiles.json
LLAMA_CPP_REPO_URL=https://github.com/ggml-org/llama.cpp.git
LLAMA_CPP_GIT_REF=master
LLAMA_CPP_CMAKE_ARGS=-DGGML_METAL=OFF -DBUILD_SHARED_LIBS=OFF
LLAMA_CPP_BUILD_JOBS=2
LLAMA_CPP_THREADS=2
LLAMA_CPP_BENCH_REPETITIONS=1
LOCAL_LLM_DOWNLOAD_TIMEOUT_SECONDS=1800
LOCAL_LLM_BENCHMARK_TIMEOUT_SECONDS=900
LOCAL_LLM_WARMUP_ON_STARTUP=true
LOCAL_LLM_WARMUP_MODELS=all
LOCAL_LLM_WARMUP_PRECISION_MODES=INT4
LOCAL_LLM_WARMUP_REQUIRED=true
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NIM_TIMEOUT_SECONDS=30
MAX_CONCURRENT_ACTIVITIES=1
LOG_LEVEL=INFO
